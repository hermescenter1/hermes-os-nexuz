# ─── Hermes OS — Environment Template ──────────────────────────────────────
# Copy to .env.local for development, .env.production for production.
# NEVER commit files that contain real secrets.

# ─── Database (Phase 11A) ─────────────────────────────────────────────────
# When unset, Hermes runs in session/in-memory mode (no DB required for dev).
DATABASE_URL="postgresql://hermes:V7#pL92!qR4xM@localhost:5432/hermes_db?schema=public"



# ─── Storage mode (Phase 11B) ─────────────────────────────────────────────
# "database" | "session" — inferred from DATABASE_URL presence when unset.
HERMES_STORAGE_MODE=database

# ─── JWT (Phase 28) ──────────────────────────────────────────────────────
# Generate real values with: openssl rand -hex 64
JWT_ACCESS_SECRET="Hamid1364%%^??@&**##??1364Asghar@@%%^??Somayeh"Hamid1364%%^??@"
JWT_REFRESH_SECRET="Asodolah$$%%^^&&**??@Hamid<<>>()Yotub@Hamid1364%%^??Mamani886"

# ─── App URL ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Email ───────────────────────────────────────────────────────────────
# EMAIL_PROVIDER options: console (dev/CI) | resend (production)
EMAIL_PROVIDER="console"
EMAIL_FROM="Hermes OS <noreply@hermesos.dev>"

# Resend (https://resend.com) — required when EMAIL_PROVIDER=resend
# RESEND_API_KEY="re_..."

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Postgres container init (Docker Compose only) ───────────────────────
POSTGRES_USER="hermes"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="hermes_db"

# ─── AI Gateway ──────────────────────────────────────────────────────────
# Brain / Copilot features are disabled without this key.
# OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ─── Document embedding (Phase 17C) ──────────────────────────────────────
# "openai" (default, 1536-dim) | "mock" (dev/test, no API key needed)
# DOCUMENT_EMBEDDINGS_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Feature flags ───────────────────────────────────────────────────────
HERMES_RAG_MODE="memory"
HERMES_PROJECT_INTELLIGENCE_ENABLED="false"

# ─── Stripe (Phase 48) ───────────────────────────────────────────────────────
# Required for paid subscriptions. Leave unset to run in manual-billing mode.
# STRIPE_SECRET_KEY="sk_live_..."         # or sk_test_... for development
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."       # Stripe Dashboard → Webhooks
#
# Billing portal: configure at dashboard.stripe.com/settings/billing/portal
# Portal URL is auto-generated — no extra env var needed.
#
# Stripe Price IDs — one per plan × billing cycle (slug = plan.slug.toUpperCase())
# STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_..."
# STRIPE_PRICE_PROFESSIONAL_YEARLY="price_..."
# STRIPE_PRICE_TEAM_MONTHLY="price_..."
# STRIPE_PRICE_TEAM_YEARLY="price_..."
# STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."
# STRIPE_PRICE_ENTERPRISE_YEARLY="price_..."
