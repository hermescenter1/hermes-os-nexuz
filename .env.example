# ─── Hermes OS — Environment Template ──────────────────────────────────────
# Copy to .env.local for development, .env.production for production.
# NEVER commit files that contain real secrets.

# ─── Database (Phase 11A) ─────────────────────────────────────────────────
# When unset, Hermes runs in session/in-memory mode (no DB required for dev).
DATABASE_URL="postgresql://hermes:changeme@localhost:5432/hermes_db"

# ─── Storage mode (Phase 11B) ─────────────────────────────────────────────
# "database" | "session" — inferred from DATABASE_URL presence when unset.
HERMES_STORAGE_MODE=database

# ─── JWT (Phase 28) ──────────────────────────────────────────────────────
# Generate real values with: openssl rand -hex 64
JWT_ACCESS_SECRET="change-this-to-a-64-char-random-hex-string-for-access-tokens"
JWT_REFRESH_SECRET="change-this-to-a-64-char-random-hex-string-for-refresh-tokens"

# ─── App URL ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Email (Phase 28) ────────────────────────────────────────────────────
# EMAIL_PROVIDER options: console (dev/CI) | smtp | sendgrid | resend
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@example.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASS="your-smtp-password"

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Postgres container init (Docker Compose only) ───────────────────────
POSTGRES_USER="hermes"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="hermes_db"

# ─── AI Gateway ──────────────────────────────────────────────────────────
# Brain / Copilot features are disabled without this key.
# OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ─── Document embedding (Phase 17C) ──────────────────────────────────────
# "openai" (default, 1536-dim) | "mock" (dev/test, no API key needed)
# DOCUMENT_EMBEDDINGS_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Feature flags ───────────────────────────────────────────────────────
HERMES_RAG_MODE="memory"
HERMES_PROJECT_INTELLIGENCE_ENABLED="false"
