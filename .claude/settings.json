{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "fable",
  "fallbackModel": [
    "opus",
    "sonnet"
  ],
  "effortLevel": "xhigh",
  "language": "persian",
  "fileCheckpointingEnabled": true,
  "showThinkingSummaries": true,
  "permissions": {
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck *)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx prisma format)",
      "Bash(npx prisma validate)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm update *)",
      "Bash(npm audit fix *)",
      "Bash(npx prisma generate *)",
      "Bash(npx prisma migrate *)",
      "Bash(npx prisma db push *)",
      "Bash(npx prisma db seed *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose build *)",
      "Bash(docker compose restart *)",
      "Bash(docker compose exec *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./certificates/**)",
      "Read(./deploy/certs/**)",
      "Read(./private/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(rm -rf *)",
      "Bash(del /s *)",
      "Bash(rmdir /s *)",
      "Bash(npx prisma migrate reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Bash(docker compose down -v*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker volume rm*)"
    ]
  }
}