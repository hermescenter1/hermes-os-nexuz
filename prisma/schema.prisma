// ─── Phase 72 — Enterprise Asset Registry ─────────────────────────────────────

enum AssetStatus {
  PLANNED
  COMMISSIONED
  IN_SERVICE
  DEGRADED
  UNDER_MAINTENANCE
  STANDBY
  RETIRED
  REPLACED
  DECOMMISSIONED
}

enum AssetCriticality {
  NON_CRITICAL
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetRiskState {
  HEALTHY
  MONITOR
  AT_RISK
  CRITICAL
  UNKNOWN
}

enum AssetLifecycleState {
  DESIGN
  PROCUREMENT
  INSTALLATION
  COMMISSIONING
  IN_SERVICE
  DEGRADED
  DECOMMISSIONING
  RETIRED
}

enum RegistryAssetType {
  PRODUCTION_LINE
  MACHINE
  PLC
  HMI
  SCADA_NODE
  ELECTRICAL_PANEL
  MCC_PANEL
  VFD
  MOTOR
  PUMP
  VALVE
  SENSOR
  INSTRUMENT
  ROBOT
  CONVEYOR
  COMPRESSOR
  UTILITY_SYSTEM
  SAFETY_SYSTEM
  NETWORK_DEVICE
  INDUSTRIAL_PC
}

model RegistryAsset {
  id                String              @id @default(cuid())
  organizationId    String?
  siteId            String?
  assetNumber       String
  name              String
  nameEn            String?
  nameFa            String?
  description       String?
  assetType         RegistryAssetType
  status            AssetStatus         @default(IN_SERVICE)
  criticality       AssetCriticality    @default(MEDIUM)
  riskState         AssetRiskState      @default(HEALTHY)
  lifecycleState    AssetLifecycleState @default(IN_SERVICE)
  healthScore       Float               @default(100)
  parentAssetId     String?
  locationId        String?
  manufacturer      String?
  model             String?
  serialNumber      String?
  firmwareVersion   String?
  installationDate  DateTime?
  commissionDate    DateTime?
  warrantyExpiry    DateTime?
  expectedLifeYears Int?
  lastInspectionAt  DateTime?
  nextInspectionAt  DateTime?
  technicalSpecs    Json                @default("{}")
  tags              String[]
  isActive          Boolean             @default(true)
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  location         AssetLocation?               @relation(fields: [locationId], references: [id])
  children         RegistryAsset[]              @relation("RegistryAssetHierarchy")
  parent           RegistryAsset?               @relation("RegistryAssetHierarchy", fields: [parentAssetId], references: [id])
  criticalities    AssetCriticalityAssessment[]
  healthSnapshots  AssetHealthSnapshot[]
  lifecycleEvents  AssetLifecycleEvent[]
  maintenanceLinks AssetMaintenanceLink[]
  documentLinks    AssetDocumentLink[]
  telemetryLinks   AssetTelemetryLink[]
  registryTags     RegistryAssetTag[]

  @@index([organizationId])
  @@index([siteId])
  @@index([assetType])
  @@index([status])
  @@index([criticality])
  @@index([parentAssetId])
  @@index([locationId])
}

model AssetLocation {
  id             String   @id @default(cuid())
  organizationId String?
  siteId         String?
  code           String
  name           String
  nameEn         String?
  nameFa         String?
  description    String?
  locationType   String   @default("AREA")
  parentId       String?
  gpsLat         Float?
  gpsLon         Float?
  building       String?
  floor          String?
  room           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assets RegistryAsset[]

  @@index([organizationId])
  @@index([siteId])
  @@index([code])
}

model AssetCriticalityAssessment {
  id                    String           @id @default(cuid())
  assetId               String
  assessedBy            String?
  safetyImpact          Int              @default(1)
  productionImpact      Int              @default(1)
  maintenanceImpact     Int              @default(1)
  downtimeRisk          Int              @default(1)
  replacementDifficulty Int              @default(1)
  spareAvailability     Int              @default(5)
  overallScore          Float            @default(0)
  criticality           AssetCriticality @default(MEDIUM)
  notes                 String?
  isActive              Boolean          @default(true)
  assessedAt            DateTime         @default(now())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model AssetHealthSnapshot {
  id           String         @id @default(cuid())
  assetId      String
  healthScore  Float
  riskState    AssetRiskState
  vibrationRms Float?
  temperature  Float?
  pressure     Float?
  currentDraw  Float?
  notes        String?
  takenBy      String?
  takenAt      DateTime       @default(now())
  createdAt    DateTime       @default(now())

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([takenAt])
}

model AssetLifecycleEvent {
  id          String               @id @default(cuid())
  assetId     String
  eventType   String
  fromState   AssetLifecycleState?
  toState     AssetLifecycleState
  performedBy String?
  notes       String?
  documents   String[]
  metadata    Json                 @default("{}")
  occurredAt  DateTime             @default(now())
  createdAt   DateTime             @default(now())

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([occurredAt])
}

model AssetMaintenanceLink {
  id          String   @id @default(cuid())
  assetId     String
  workOrderId String?
  planId      String?
  linkType    String   @default("WORK_ORDER")
  notes       String?
  linkedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([workOrderId])
}

model AssetDocumentLink {
  id          String   @id @default(cuid())
  assetId     String
  documentId  String?
  docType     String   @default("MANUAL")
  title       String
  description String?
  fileRef     String?
  linkedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([documentId])
}

model AssetTelemetryLink {
  id          String   @id @default(cuid())
  assetId     String
  tagPath     String
  protocol    String   @default("OPC_UA")
  description String?
  unit        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([tagPath])
}

model RegistryAssetTag {
  id        String   @id @default(cuid())
  assetId   String
  key       String
  value     String
  createdAt DateTime @default(now())

  asset RegistryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([key])
}

// --- Phase 72.5 - Hermes Industrial Knowledge Network ---

enum ArtStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ArtVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ArtContentType {
  TECHNICAL_ARTICLE
  INDUSTRIAL_CASE_STUDY
  TROUBLESHOOTING_REPORT
  PROJECT_REPORT
  MAINTENANCE_INSIGHT
  PLC_SCADA_TUTORIAL
  FAILURE_ANALYSIS
  ASSET_RELIABILITY_NOTE
  ENGINEERING_OPINION
  RESEARCH_SUMMARY
  FIELD_COMMISSIONING_NOTE
  SAFETY_COMPLIANCE_NOTE
}

enum ArtLanguage {
  EN
  FA
}

enum ArtReactionType {
  INSIGHTFUL
  HELPFUL
  DETAILED
  PRACTICAL
}

model Article {
  id                 String         @id @default(cuid())
  title              String
  slug               String         @unique
  subtitle           String?
  excerpt            String?
  content            String         @db.Text
  coverImageUrl      String?
  language           ArtLanguage    @default(EN)
  contentType        ArtContentType @default(TECHNICAL_ARTICLE)
  status             ArtStatus      @default(DRAFT)
  visibility         ArtVisibility  @default(PUBLIC)
  authorId           String
  categoryId         String?
  readingTimeMinutes Int            @default(5)
  publishedAt        DateTime?
  viewCount          Int            @default(0)
  saveCount          Int            @default(0)
  reactionCount      Int            @default(0)
  commentCount       Int            @default(0)
  shareCount         Int            @default(0)
  seoTitle           String?
  seoDescription     String?
  canonicalUrl       String?
  ogImageUrl         String?
  noIndex            Boolean        @default(false)
  rejectionReason    String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  author            ArticleAuthorProfile      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category          ArticleCategory?          @relation(fields: [categoryId], references: [id])
  tags              ArticleTagOnArticle[]
  saves             ArticleSave[]
  reactions         ArticleReaction[]
  comments          ArticleComment[]
  views             ArticleView[]
  shares            ArticleShare[]
  reports           ArticleReport[]
  moderationEvents  ArticleModerationEvent[]
  editorialReviews  ArticleEditorialReview[]
  qualitySignals    ArticleQualitySignal[]
  knowledgeMetadata ArticleKnowledgeMetadata?
  readingHistory    ArticleReadingHistory[]

  @@index([status, visibility])
  @@index([authorId])
  @@index([categoryId])
  @@index([slug])
  @@index([publishedAt])
  @@index([language])
}

model ArticleAuthorProfile {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  handle                     String   @unique
  displayName                String
  headline                   String?
  bio                        String?  @db.Text
  company                    String?
  roleTitle                  String?
  expertiseAreas             String[]
  location                   String?
  avatarUrl                  String?
  bannerUrl                  String?
  followerCount              Int      @default(0)
  articleCount               Int      @default(0)
  totalViews                 Int      @default(0)
  totalSaves                 Int      @default(0)
  verifiedExpert             Boolean  @default(false)
  industrialCredibilityScore Float?
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  articles  Article[]
  followers ArticleFollow[] @relation("Following")
  following ArticleFollow[] @relation("Follower")

  @@index([handle])
  @@index([userId])
}

model ArticleCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameFa      String
  description String?
  color       String   @default("signal")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([slug])
}

model ArticleTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  nameFa    String?
  createdAt DateTime @default(now())

  articles ArticleTagOnArticle[]

  @@index([slug])
}

model ArticleTagOnArticle {
  articleId String
  tagId     String

  article Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model ArticleFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  ArticleAuthorProfile @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following ArticleAuthorProfile @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ArticleSave {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
}

model ArticleReaction {
  id           String          @id @default(cuid())
  userId       String
  articleId    String
  reactionType ArtReactionType
  createdAt    DateTime        @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model ArticleComment {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  parentId  String?
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent  ArticleComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies ArticleComment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([userId])
}

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  userId    String?
  ipHash    String?
  userAgent String?
  viewedAt  DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([viewedAt])
}

model ArticleShare {
  id        String   @id @default(cuid())
  articleId String
  userId    String?
  platform  String   @default("COPY")
  sharedAt  DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleReport {
  id         String   @id @default(cuid())
  articleId  String
  reporterId String
  reason     String
  detail     String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([resolved])
}

model ArticleModerationEvent {
  id          String   @id @default(cuid())
  articleId   String
  moderatorId String
  action      String
  reason      String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleEditorialReview {
  id         String   @id @default(cuid())
  articleId  String
  reviewerId String
  verdict    String
  feedback   String?  @db.Text
  quality    Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleQualitySignal {
  id         String   @id @default(cuid())
  articleId  String
  signalType String
  score      Float
  computedBy String   @default("SYSTEM")
  computedAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleKnowledgeMetadata {
  id                      String   @id @default(cuid())
  articleId               String   @unique
  knowledgeEligible       Boolean  @default(false)
  reviewedForKnowledge    Boolean  @default(false)
  articleQualityScore     Float?
  sourceReliability       String?
  evidenceLevel           String?
  industrialDomain        String?
  linkedAssetType         String?
  linkedFailureMode       String?
  linkedTechnology        String?
  linkedStandard          String?
  linkedVendor            String?
  linkedPLCPlatform       String?
  linkedMaintenanceDomain String?
  safetyCritical          Boolean  @default(false)
  humanReviewed           Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ArticleReadingHistory {
  id          String    @id @default(cuid())
  userId      String
  articleId   String
  progressPct Int       @default(0)
  completedAt DateTime?
  lastReadAt  DateTime  @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
}

// ── Phase 79: Sales entry / demo request lead capture ──────────────────────────

model SalesLead {
  id            String  @id @default(cuid())
  fullName      String
  email         String
  phone         String?
  company       String?
  roleTitle     String?
  country       String?
  industry      String?
  companySize   String?
  interest      String?
  useCase       String? @db.Text
  preferredDemo String?
  message       String? @db.Text
  source        String  @default("WEBSITE")
  locale        String?
  status        String  @default("NEW")
  ipHash        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
