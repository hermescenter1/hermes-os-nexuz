// Hermes OS — Phase 11A database foundation.
//
// This schema describes the Phase 2 Postgres persistence layer. In V1 it is
// OPTIONAL: when DATABASE_URL is absent the app runs entirely in session mode
// and never touches Prisma. Models mirror the existing JSON/session shapes so
// migration is a straight copy when the database is provisioned.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
}

model EngineeringCase {
  id                String   @id @default(cuid())
  title             String
  vendor            String
  domain            String
  problem           String
  rootCause         String
  secondaryCauses   Json
  verificationSteps Json
  correctiveActions Json
  safetyNotes       String
  tags              Json
  confidence        Int
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KnowledgeArticle {
  id                String   @id @default(cuid())
  title             String
  domain            String
  vendor            String?
  summary           String
  content           String
  failureModes      Json
  diagnosticGuidance Json
  verificationSteps Json
  correctiveActions Json
  safetyNotes       String
  tags              Json
  confidence        Int
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AnalysisRecord {
  id         String   @id @default(cuid())
  query      String
  locale     String
  mode       String
  domains    Json
  vendors    Json
  cases      Json
  knowledge  Json
  confidence Float
  riskLevel  String
  isUnknown  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model UnknownAnalysis {
  id               String   @id @default(cuid())
  query            String
  locale           String
  confidence       Float
  suggestedDomains Json
  suggestedVendors Json
  status           String   @default("open")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---- Phase 16A: document ingestion foundation (additive; no upload route,
// no extraction, no embedding wiring yet) ----
//
// `Document` is the source-file metadata row — title, status, and a
// `storageKey` POINTER into object storage (MinIO/S3-compatible; see
// src/lib/documents/object-storage.ts). The raw file bytes are never
// stored here. `DocumentChunk` below (Phase 14C) is the per-chunk
// embedding store a future ingestion worker (Phase 16B) will populate from
// a Document's extracted text.
//
// Deliberately NO foreign key from `DocumentChunk.documentId` to
// `Document.id`: Phase 15's Brain<->RAG integration already writes
// DocumentChunk rows (when HERMES_RAG_MODE=pgvector) whose `documentId` is
// an EngineeringCase or knowledge-library id, not a real Document row — a
// hard FK would break that existing, working path. The two tables stay
// loosely coupled by convention, exactly as `DocumentChunk`'s own Phase
// 14C header comment already documents.
model Document {
  id                String    @id @default(cuid())
  title             String
  sourceType        String
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  storageProvider   String    @default("local")
  storageKey        String
  extractedTextKey  String?
  contentHash       String?
  metadata          Json      @default("{}")
  status            String    @default("uploaded")
  error             String?
  chunkCount        Int       @default(0)
  // Phase 16C: set whenever POST /api/documents/[id]/process completes
  // (success or failure) — distinct from `updatedAt`, which already
  // changes on the upload flow's own internal storageKey-set step.
  lastProcessedAt   DateTime?
  uploadedBy        String?
  tenantId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([sourceType])
}

// ---- Phase 16C: pre-embedding chunk storage (additive) ----
//
// `DocumentTextChunk` holds chunk TEXT only — no embedding, no vector
// column. Deliberately a SEPARATE model from `DocumentChunk` above
// (Phase 14C): that table's `embedding` column is NOT NULL pgvector, so it
// cannot represent a chunk that has no embedding yet. Phase 16D's
// embedding step is expected to read these rows and write the
// corresponding `DocumentChunk` row once a real embedding provider is
// wired in — the two tables are pipeline stages, not duplicates.
//
// No foreign key to `Document` — consistent with `DocumentChunk`'s own
// loose-coupling-by-convention (see that model's comment); application
// code (the DELETE /api/documents/[id] route) is responsible for cleaning
// up a document's chunks when the document itself is deleted.
//
// ---- Phase 16D / 17C: embedding columns (Phase 16D additive; Phase 17C resize) ----
//
// `embedding` uses the same `Unsupported(...)` escape hatch as
// `DocumentChunk.embedding` above. Phase 16D used vector(64) for the mock
// provider; Phase 17C resizes to vector(1536) to match text-embedding-3-small
// (the same dimension as DocumentChunk — both tables now share the same vector
// space). See src/lib/documents/config.ts's `DOCUMENT_CHUNK_EMBEDDING_DIMENSIONS`
// for the single source of truth this literal must match, and
// src/lib/documents/chunk-vector-store.ts for the raw-SQL-only access
// this column requires (invisible to the typed Prisma client, exactly
// like `DocumentChunk.embedding`).
model DocumentTextChunk {
  id                  String                     @id @default(cuid())
  documentId          String
  position            Int
  text                String
  charCount           Int
  tokenCount          Int?
  contentHash         String?
  metadata            Json                       @default("{}")
  status              String                     @default("chunked")
  embedding           Unsupported("vector(1536)")?
  embeddingModel      String?
  embeddingDimensions Int?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([documentId, position])
  @@index([documentId])
}

// ---- Phase 14C: RAG persistence (additive; NOT wired into /api/brain) ----
//
// `embedding` uses Prisma's `Unsupported(...)` escape hatch: pgvector's
// `vector` type has no native Prisma equivalent, so this column is invisible
// to the generated Prisma Client — every read/write against it goes through
// raw SQL in `src/lib/rag/vector-store-pgvector.ts`, exactly like every
// other column below is reachable through the typed client as usual.
//
// The `vector` extension itself is enabled by the migration's own SQL
// (`CREATE EXTENSION IF NOT EXISTS vector;` — see
// prisma/migrations/20260616000000_add_document_chunk_pgvector/migration.sql),
// not by Prisma's `extensions =` datasource block — deliberately avoided so
// this phase doesn't also have to adopt the `postgresqlExtensions` preview
// feature for one column.
//
// Dimension is fixed at 1536 (OpenAI's text-embedding-3-small — see
// src/lib/rag/config.ts's PGVECTOR_DIMENSIONS, the single source of truth
// this literal must match). A pgvector column's width cannot be altered in
// place without rewriting every row; switching the canonical embedding
// model/dimension requires a NEW migration, not an edit to this one.
//
// `model`/`dimensions` are stored per-row (not just relied on globally) so
// a future re-embedding migration can identify which rows came from which
// provider/model before rewriting them.
model DocumentChunk {
  id         String                @id
  documentId String
  sourceType String
  text       String
  position   Int
  metadata   Json                  @default("{}")
  model      String
  dimensions Int
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([documentId])
  @@index([sourceType])
  // The HNSW similarity index (`CREATE INDEX ... USING hnsw (embedding
  // vector_cosine_ops)`) lives only in the migration SQL — Prisma's schema
  // language has no `@@index` syntax for an operator-class-based index
  // type, so it cannot be expressed here.
}

// ---- Phase 19A: Project Intelligence Foundation (additive) ----
//
// `Project` is an organisational context that memories (and future artefacts)
// can be tagged with. Not required — all existing fields remain optional.
// Memories in the same project receive a ranking boost during retrieval
// (Phase 19A WEIGHTS.PROJECT = 20 pts) when HERMES_PROJECT_INTELLIGENCE_ENABLED.
model Project {
  id          String              @id @default(cuid())
  name        String
  description String
  status      String              @default("active")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memories    EngineeringMemory[]

  @@index([status])
}

// ---- Phase 18A: Engineering Memory Foundation (additive) ----
//
// `EngineeringMemory` is an explicitly-saved engineering analysis record.
// Not auto-populated on every Brain request (Phase 18C will add that).
// Operators/engineers POST notable analyses to /api/memory; field feedback
// is collected via /api/memory/[id]/feedback in `MemoryFeedback`.
//
// `outcome` on `EngineeringMemory` mirrors the latest feedback outcome for
// quick filtering. `MemoryFeedback` is the append-only audit trail.
//
// `projectId` (Phase 19A, nullable): optional link to a Project record.
// SET NULL on project delete keeps the memory row intact.
model EngineeringMemory {
  id                 String           @id @default(cuid())
  query              String
  domain             String
  analysisSummary    String
  confidence         Float
  relatedCaseIds     Json             @default("[]")
  relatedDocumentIds Json             @default("[]")
  outcome            String           @default("unknown")
  notes              String?
  projectId          String?
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  feedback           MemoryFeedback[]

  @@index([domain])
  @@index([outcome])
  @@index([projectId])
}

model MemoryFeedback {
  id          String            @id @default(cuid())
  memoryId    String
  outcome     String
  notes       String?
  submittedBy String?
  createdAt   DateTime          @default(now())
  memory      EngineeringMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
}

// ---- Phase 12A / Phase 28: authentication + RBAC ----

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  role                 String               @default("customer") // superadmin | admin | engineer | customer | viewer
  // Phase 28: email verification
  emailVerified        Boolean              @default(false)
  emailVerifiedAt      DateTime?
  // Phase 28: brute-force protection
  failedLoginAttempts  Int                  @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  sessions             AuthSession[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  verificationTokens   VerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  organizationMembers  OrganizationMember[]
  // Phase 43: Site Isolation
  userSites            UserSite[]
  // Phase 48: Notification System
  notifications        Notification[]
  // Phase 58B: ATS Candidate profile (optional — only registered candidates)
  atsCandidate         AtsCandidate?
  // Phase 60: Academy
  academyEnrollments   AcademyEnrollment[]
  academyProgress      AcademyProgress[]
  academyCertificates  AcademyCertificate[]
  academyQuizAttempts  AcademyQuizAttempt[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 28: JWT refresh token (stored as SHA-256 hash, never plaintext)
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Phase 28: email verification tokens (plaintext — one-time use)
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Phase 28: password-reset tokens (stored as SHA-256 hash)
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([userId])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 31 — SaaS Billing Engine Foundation
// ════════════════════════════════════════════════════════════════════════════
//
// Monetary fields: Decimal @db.Decimal(20, 4)
//   — 20 total digits, 4 decimal places.
//   — IRR has no minor units (formatting rounds to 0 dp); GBP/USD/EUR use 2 dp.
//     Storing 4 dp everywhere gives uniform precision without data loss.
//
// One-active-subscription invariant: a given Organization must have at most
// ONE subscription in a non-terminal state (ACTIVE | TRIALING | PAST_DUE) at
// a time. This is enforced in service logic (src/lib/billing/subscriptions.ts)
// rather than a DB constraint because Prisma has no partial-unique-index DSL.

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  ENGINEER
  VIEWER
  BILLING_ADMIN
  MEMBER         // deprecated — migrated to ENGINEER in Phase 32
  // Phase 58B: ATS roles
  HR_MANAGER
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  // Phase 60: Academy roles
  ACADEMY_ADMIN
  CUSTOMER_SUCCESS_MANAGER
  STUDENT
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum Currency {
  IRR
  GBP
  USD
  EUR
}

// ── Organization ─────────────────────────────────────────────────────────────

// Phase 32: extended with description, website, logoUrl, settings
model Organization {
  id            String                   @id @default(cuid())
  name          String
  slug          String                   @unique
  description   String?
  website       String?
  logoUrl       String?
  settings         Json    @default("{}")
  // Phase 48C: Stripe integration
  stripeCustomerId String? @unique
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  members              OrganizationMember[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  usageRecords         UsageRecord[]
  invitations          OrganizationInvitation[]
  departments          Department[]
  apiKeys              ApiKey[]
  industrialSites      IndustrialSite[]
  industrialGateways   IndustrialGateway[]
  industrialAssets     IndustrialAsset[]
  telemetryRecords     TelemetryRecord[]
  connectorConfigs     IndustrialConnectorConfig[]
  // Phase 36: Digital Twin
  digitalTwinNodes     DigitalTwinNode[]
  digitalTwinRelations DigitalTwinRelation[]
  digitalTwinLayouts   DigitalTwinLayout[]
  assetTags            AssetTag[]
  // Phase 37: Time Series Analytics
  analyticsSnapshots   AnalyticsSnapshot[]
  kpiRecords           KPIRecord[]
  assetHealthHistory   AssetHealthHistory[]
  // Phase 38: Industrial Copilot
  copilotConversations CopilotConversation[]
  copilotInsights      CopilotInsight[]
  // Phase 39: Predictive Maintenance
  assetBaselines       AssetBaseline[]
  assetRiskScores      AssetRiskScore[]
  failureIndicators    FailureIndicator[]
  rulSnapshots         RULSnapshot[]
  maintenanceRecs      MaintenanceRecommendation[]
  // Phase 40: Industrial Knowledge Engine
  knowledgeCategories  KnowledgeCategory[]
  knowledgeArticles    IndustrialKnowledgeArticle[]
  failureModes         IndustrialFailureMode[]
  rootCauses           IndustrialRootCause[]
  maintenanceProcs     IndustrialMaintenanceProcedure[]
  engineeringCases     IndustrialEngineeringCase[]
  assetKnowledgeLinks  AssetKnowledgeLink[]
  // Phase 41: Industrial Knowledge Graph
  kgNodes              IndustrialKnowledgeGraphNode[]
  kgEdges              IndustrialKnowledgeGraphEdge[]
  kgSnapshots          KnowledgeGraphSnapshot[]
  // Phase 42: Multi-Site Industrial Intelligence
  multiSiteBenchmarks  MultiSiteBenchmark[]
  siteRiskSnapshots    SiteRiskSnapshot[]
  siteKpiComparisons   SiteKPIComparison[]
  crossSitePatterns    CrossSiteFailurePattern[]
  // Phase 43: Site Isolation
  userSites            UserSite[]
  // Phase 49: Asset Intelligence Automation
  assetAlerts          AssetAlert[]
  intelligenceSnapshots AssetIntelligenceSnapshot[]
  // Phase 58B: ATS Persistence
  atsJobs              AtsJob[]
  atsApplications      AtsApplication[]
  atsInterviews        AtsInterview[]
  atsPipelineEvents    AtsPipelineEvent[]
  atsCandidateScores   AtsCandidateScore[]
  // Phase 60: Academy
  academyCourses       AcademyCourse[]
  academyEnrollments   AcademyEnrollment[]
  academyCertificates  AcademyCertificate[]
}

// Phase 32: extended with status, department, invitedBy, joinedAt, updatedAt
model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole                  @default(ENGINEER)
  status         MemberStatus             @default(ACTIVE)
  departmentId   String?
  invitedById    String?                  // userId of inviter (loose reference — no FK)
  joinedAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department?              @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepts   Department[]             @relation("DepartmentManager")

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@index([departmentId])
}

// ── Organization Invitations ──────────────────────────────────────────────────

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole          @default(ENGINEER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String?          // userId (loose reference — no FK)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

// ── Departments ───────────────────────────────────────────────────────────────

model Department {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           String               // "automation" | "electrical" | "maintenance" | "production" | "management" | "it_ot"
  managerId      String?              // OrganizationMember.id
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager        OrganizationMember?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  members        OrganizationMember[] @relation("DepartmentMembers")

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ── Plans ─────────────────────────────────────────────────────────────────────

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  monthlyPrice  Decimal        @db.Decimal(20, 4)
  yearlyPrice   Decimal        @db.Decimal(20, 4)
  currency      Currency       @default(USD)
  features      Json           @default("[]")
  limits        Json           @default("{}")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  planId         String
  status         SubscriptionStatus @default(TRIALING)
  billingCycle   BillingCycle       @default(MONTHLY)
  startsAt       DateTime
  expiresAt      DateTime
  autoRenew            Boolean @default(true)
  // Phase 48C: Stripe subscription reference
  stripeSubscriptionId String? @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan               @relation(fields: [planId], references: [id])
  invoices       Invoice[]

  @@index([organizationId])
  @@index([status])
}

// ── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  subscriptionId String
  invoiceNumber  String        @unique
  currency       Currency
  subtotal       Decimal       @db.Decimal(20, 4)
  tax            Decimal       @db.Decimal(20, 4) @default(0)
  total          Decimal       @db.Decimal(20, 4)
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  payments       Payment[]

  @@index([organizationId])
  @@index([status])
}

// ── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  invoiceId         String
  provider          String        // "manual" | future: "stripe" | "zarinpal"
  providerReference String?       @unique // nullable until a real provider is attached
  amount            Decimal       @db.Decimal(20, 4)
  currency          Currency
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  invoice           Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

// ── API Keys ──────────────────────────────────────────────────────────────────
//
// Security invariant: the raw key is NEVER stored. We store only a SHA-256
// hash of the full key string. SHA-256 is correct here — do NOT upgrade to
// bcrypt. API keys are high-entropy random values (not passwords), so preimage
// resistance from bcrypt adds no security and adds latency. Timing-safe
// comparison (crypto.timingSafeEqual) prevents hash-timing attacks.
//
// Lookup flow: find record by prefix (indexed, plaintext) → then verify hash.
// This avoids a full-table hash scan.

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  // keyHash: SHA-256 hex of the full key. Unique to prevent duplicate-key collisions.
  keyHash        String       @unique
  // prefix: first 8 chars of the random portion; stored plaintext for O(1) lookup.
  prefix         String       @unique
  // last4: last 4 chars of the full key, shown in the dashboard for identification.
  last4          String
  // scopes: JSON array of scope strings e.g. ["projects.read", "telemetry.write"]
  scopes         Json         @default("[]")
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdById    String?      // userId (loose reference — no FK)
  revokedAt      DateTime?
  revokedById    String?      // userId (loose reference — no FK)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateways       IndustrialGateway[] // Phase 35: gateways bound to this key

  @@index([organizationId])
}

// ── Usage Records ─────────────────────────────────────────────────────────────

model UsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  // Phase 48C: optional per-user tracking alongside org-level
  userId         String?
  metric         String       // "ai_requests" | "projects" | "members" | "storage_gb" | "api_calls" | "emails_sent" | "notifications_created"
  value          Decimal      @db.Decimal(20, 4)
  recordedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([metric])
  @@index([userId])
}

// ── Industrial Gateway Foundation — Phase 35 ─────────────────────────────────
//
// SAFETY INVARIANT: Hermes Cloud is READ/OBSERVE ONLY in this phase.
// Do NOT implement write-back commands to PLCs, actuators, or control systems.
// Any command path to industrial hardware requires a separate safety review
// outside the scope of this codebase.

// ── Enums ─────────────────────────────────────────────────────────────────────

enum IndustrialSiteStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum IndustrialGatewayStatus {
  ONLINE
  OFFLINE
  DEGRADED
  REVOKED
}

enum IndustrialAssetType {
  PLC
  SCADA
  HMI
  MOTOR
  PUMP
  COMPRESSOR
  CONVEYOR
  SENSOR
  DRIVE
  PANEL
  // Phase 48 additions
  VFD
  VALVE
  OTHER
}

enum IndustrialProtocol {
  OPC_UA
  MQTT
  MODBUS_TCP
  SIEMENS_S7
  SCADA
  HISTORIAN
  MANUAL
  OTHER
}

enum TelemetryQuality {
  GOOD
  BAD
  UNCERTAIN
  STALE
}

enum ConnectorType {
  OPC_UA
  MQTT
  MODBUS_TCP
  SIEMENS_S7
  SCADA
  HISTORIAN
}

// ── Industrial Site ───────────────────────────────────────────────────────────

model IndustrialSite {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  slug           String
  location       String?
  description    String?
  status         IndustrialSiteStatus @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateways       IndustrialGateway[]
  assets         IndustrialAsset[]
  connectors     IndustrialConnectorConfig[]
  telemetry      TelemetryRecord[]
  // Phase 36: Digital Twin
  twinNodes      DigitalTwinNode[]
  twinLayouts    DigitalTwinLayout[]
  // Phase 43: Site Isolation
  userSites      UserSite[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ── Industrial Gateway ────────────────────────────────────────────────────────

model IndustrialGateway {
  id             String                  @id @default(cuid())
  organizationId String
  siteId         String
  name           String
  // gatewayId: external hardware identifier (e.g. serial number). Globally unique.
  gatewayId      String                  @unique
  status         IndustrialGatewayStatus @default(OFFLINE)
  version        String?
  // apiKeyId: the specific ApiKey this gateway must authenticate with.
  // key↔gateway binding: ctx.keyId MUST equal this value on every ingest/heartbeat.
  apiKeyId       String?
  lastSeenAt     DateTime?
  metadata       Json                    @default("{}")
  revokedAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           IndustrialSite          @relation(fields: [siteId], references: [id])
  apiKey         ApiKey?                 @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  assets         IndustrialAsset[]
  connectors     IndustrialConnectorConfig[]
  telemetry      TelemetryRecord[]

  @@index([organizationId])
  @@index([siteId])
  @@index([apiKeyId])
}

// ── Industrial Asset ──────────────────────────────────────────────────────────

model IndustrialAsset {
  id             String              @id @default(cuid())
  organizationId String
  siteId         String
  gatewayId      String?
  name           String
  assetType      IndustrialAssetType @default(OTHER)
  manufacturer   String?
  model          String?
  protocol       IndustrialProtocol  @default(OTHER)
  tagPrefix      String?
  status         String              @default("ACTIVE")
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           IndustrialSite      @relation(fields: [siteId], references: [id])
  gateway        IndustrialGateway?  @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  telemetry      TelemetryRecord[]
  // Phase 36: Digital Twin
  twinNodes      DigitalTwinNode[]
  assetTags      AssetTag[]

  @@index([organizationId])
  @@index([siteId])
  @@index([gatewayId])
}

// ── Telemetry Records ─────────────────────────────────────────────────────────
//
// SCALING NOTE: This table grows at (gateways × tags × poll_rate).
// A 100-gateway site at 1Hz with 500 tags = ~4.3B rows/day.
//
// PARTITIONING CANDIDATE — design is partition-ready:
//   - receivedAt is server-set (safe partition key, never client-supplied)
//   - No circular FKs that would block partition attachment
//   - Composite indexes mirror partition boundary query patterns
// Implementation: PostgreSQL PARTITION BY RANGE(receivedAt), or TimescaleDB
// hypertable on receivedAt. Retention: raw 30d → aggregated 1y.
// DO NOT implement partitioning in this phase. Add as Phase 36+ migration.
//
// FIELD TRUST LEVELS:
//   timestamp   = GATEWAY-REPORTED, UNTRUSTED (may be wrong, backdated, missing tz)
//   receivedAt  = SERVER-SET ONLY, never read from the ingestion payload

model TelemetryRecord {
  id             String           @id @default(cuid())
  organizationId String
  siteId         String
  gatewayId      String
  assetId        String?
  tag            String
  value          Json
  numericValue   Float?           // denormalized for fast numeric range queries
  quality        TelemetryQuality @default(GOOD)
  unit           String?
  source         String
  timestamp      DateTime         // gateway-reported, untrusted
  receivedAt     DateTime         @default(now()) // ALWAYS server-set
  // sequenceId: gateway-assigned monotonic ID for offline buffering.
  // Stored now; UNIQUE(gatewayId, sequenceId) deduplication added in Phase 36+.
  sequenceId     String?
  organization   Organization     @relation(fields: [organizationId], references: [id])
  site           IndustrialSite   @relation(fields: [siteId], references: [id])
  gateway        IndustrialGateway @relation(fields: [gatewayId], references: [id])
  asset          IndustrialAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([organizationId, assetId, timestamp])
  @@index([gatewayId, timestamp])
  @@index([organizationId, tag, timestamp])
  @@index([organizationId, receivedAt])
}

// ── Connector Config ──────────────────────────────────────────────────────────
// Stores connector configuration per gateway. No real protocol drivers in Phase 35.
// Phase 36+ will instantiate IndustrialConnector instances from these configs.

model IndustrialConnectorConfig {
  id             String          @id @default(cuid())
  organizationId String
  siteId         String
  gatewayId      String
  connectorType  ConnectorType
  name           String
  enabled        Boolean         @default(false)
  config         Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           IndustrialSite  @relation(fields: [siteId], references: [id])
  gateway        IndustrialGateway @relation(fields: [gatewayId], references: [id])

  @@index([organizationId])
  @@index([gatewayId])
}

// ── Digital Twin Engine — Phase 36 ───────────────────────────────────────────
//
// READ/OBSERVE ONLY INVARIANT:
// Digital Twin and Brain integration must NEVER create, suggest, or expose
// direct PLC control commands. This layer is for observation and analysis only.
//
// The Digital Twin models the factory structure as a typed graph:
//   Organization → Site → Area → Line → Cell → Asset/System
// Relationships between nodes are stored as directed or bidirectional edges.

// ── Enums ─────────────────────────────────────────────────────────────────────

enum DigitalTwinNodeType {
  SITE   // top-level physical location (usually mirrors IndustrialSite)
  AREA   // production area within a site (e.g. "Welding Shop", "Assembly Hall")
  LINE   // production line within an area
  CELL   // work cell or process unit within a line
  ASSET  // leaf node — maps to an IndustrialAsset
  SYSTEM // cross-cutting system (e.g. MES, SCADA, Historian) — no IndustrialAsset
}

enum DigitalTwinRelationType {
  PART_OF      // directed: child PART_OF parent  (e.g. pump is part of cooling system)
  CONNECTED_TO // bidirectional: physical connection between two nodes
  CONTROLS     // directed: source CONTROLS target (e.g. PLC controls motor)
  MONITORS     // directed: source MONITORS target (e.g. sensor monitors conveyor)
  FEEDS        // directed: source FEEDS target    (e.g. conveyor A feeds conveyor B)
  BACKUP_FOR   // directed: source is backup for target
}

// ── DigitalTwinNode ───────────────────────────────────────────────────────────
//
// Represents one node in the factory topology graph.
// AREA / LINE / CELL / SYSTEM nodes have no corresponding IndustrialAsset.
// ASSET nodes link to an IndustrialAsset via assetId.
// Hierarchy is expressed via PART_OF relations (not parentNodeId alone),
// but parentNodeId is kept for fast tree queries without full graph traversal.

model DigitalTwinNode {
  id             String              @id @default(cuid())
  organizationId String
  siteId         String
  assetId        String?             // null for AREA / LINE / CELL / SYSTEM nodes
  parentNodeId   String?             // convenience parent pointer; canonical hierarchy uses PART_OF
  displayName    String
  nodeType       DigitalTwinNodeType
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           IndustrialSite      @relation(fields: [siteId], references: [id])
  asset          IndustrialAsset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  parent         DigitalTwinNode?    @relation("NodeParent", fields: [parentNodeId], references: [id], onDelete: SetNull)
  children       DigitalTwinNode[]   @relation("NodeParent")
  outboundEdges  DigitalTwinRelation[] @relation("RelationSource")
  inboundEdges   DigitalTwinRelation[] @relation("RelationTarget")

  @@index([organizationId, siteId])
  @@index([organizationId])
  @@index([assetId])
}

// ── DigitalTwinRelation ───────────────────────────────────────────────────────
//
// Direction semantics (enforced in traversal code):
//   CONNECTED_TO  — bidirectional  (both directions during graph traversal)
//   FEEDS         — directed       (source → target)
//   CONTROLS      — directed       (source → target)
//   PART_OF       — directed       (source → target / "source is part of target")
//   MONITORS      — directed       (source → target)
//   BACKUP_FOR    — directed       (source → target / "source backs up target")
//
// @@unique prevents duplicate edges of the same type between the same node pair.

model DigitalTwinRelation {
  id             String                  @id @default(cuid())
  organizationId String
  sourceNodeId   String
  targetNodeId   String
  relationType   DigitalTwinRelationType
  metadata       Json                    @default("{}")
  createdAt      DateTime                @default(now())
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceNode     DigitalTwinNode         @relation("RelationSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode     DigitalTwinNode         @relation("RelationTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, relationType])
  @@index([organizationId, sourceNodeId])
  @@index([organizationId, targetNodeId])
}

// ── DigitalTwinLayout ─────────────────────────────────────────────────────────
// Persists canvas layout data (node positions, zoom, pan) per site.
// layoutData is free-form JSON understood only by the frontend renderer.

model DigitalTwinLayout {
  id             String       @id @default(cuid())
  organizationId String
  siteId         String
  name           String
  layoutData     Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           IndustrialSite @relation(fields: [siteId], references: [id])

  @@index([organizationId, siteId])
}

// ── AssetTag ──────────────────────────────────────────────────────────────────
//
// Maps an IndustrialAsset to its telemetry tag paths.
// tagPath corresponds to TelemetryRecord.tag (same format, same pattern).
// Strict foreign-key enforcement between AssetTag.tagPath and
// TelemetryRecord.tag is deferred to Phase 37+ — stored now for mapping.
// Phase 37+ will join on (assetId, tagPath) to correlate telemetry with assets.

model AssetTag {
  id             String         @id @default(cuid())
  organizationId String
  assetId        String
  tagName        String         // human-readable label
  tagPath        String         // matches TelemetryRecord.tag format
  unit           String?
  dataType       String         @default("float") // float | int | bool | string | enum
  description    String?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset          IndustrialAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagPath])
  @@index([organizationId, assetId])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 37 — Time Series Analytics Engine
// ════════════════════════════════════════════════════════════════════════════
//
// siteId/assetId are loose references (no FK) on high-write analytics tables
// to avoid FK constraint overhead at telemetry ingestion scale.
// organizationId IS always present for multi-tenant isolation.

model AnalyticsSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  siteId         String?
  assetId        String?
  metric         String       // "availability" | "efficiency" | "health_score" | "runtime" | "downtime"
  period         String       // "lastHour" | "last24Hours" | "last7Days" | "last30Days" | ISO range
  value          Float
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
  @@index([organizationId, metric, createdAt])
}

model KPIRecord {
  id             String       @id @default(cuid())
  organizationId String
  siteId         String?
  assetId        String?
  kpiName        String       // "availability" | "runtime" | "downtime" | "efficiency"
  value          Float
  period         String
  calculatedAt   DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, kpiName, calculatedAt])
  @@index([organizationId, assetId, calculatedAt])
}

model AssetHealthHistory {
  id             String       @id @default(cuid())
  organizationId String
  assetId        String
  healthScore    Float        // 0–100
  healthStatus   String       // "healthy" | "degraded" | "critical" | "unknown"
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 38 — Industrial Copilot Foundation
// ════════════════════════════════════════════════════════════════════════════
//
// READ-ONLY COPILOT INVARIANT:
// The Copilot observes, analyzes, explains, and recommends.
// It MUST NOT control equipment, send commands, modify PLC values, or execute
// autonomous actions. No write path to industrial hardware exists in this module.
//
// DETERMINISTIC: All responses are produced by template/intent formatting
// over the deterministic insight, analytics, and graph engines.
// No LLM is used in this phase.

enum CopilotMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum CopilotInsightSeverity {
  INFO
  WARNING
  CRITICAL
}

model CopilotConversation {
  id             String             @id @default(cuid())
  organizationId String
  userId         String?
  title          String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       CopilotMessage[]

  @@index([organizationId, createdAt])
}

model CopilotMessage {
  id             String               @id @default(cuid())
  conversationId String
  role           CopilotMessageRole
  content        String
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now())
  conversation   CopilotConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model CopilotInsight {
  id             String                 @id @default(cuid())
  organizationId String
  siteId         String?
  assetId        String?
  insightType    String  // "stale_telemetry" | "repeated_fault" | "declining_health" | "abnormal_kpi" | "frequent_alarms" | "missing_telemetry" | "disconnected_asset"
  severity       CopilotInsightSeverity @default(INFO)
  title          String
  description    String
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, assetId, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 39 — Predictive Maintenance Foundation
// ════════════════════════════════════════════════════════════════════════════
//
// SAFETY INVARIANT: Predictive Maintenance is READ/OBSERVE/ANALYZE ONLY.
// It MUST NOT execute maintenance, control equipment, write to PLCs, modify
// assets, or act autonomously. All outputs are recommendations backed by
// traceable evidence.
//
// AUDITABILITY: Every persisted prediction records formulaVersion and
// weightSetVersion in metadata so historical predictions remain interpretable
// after the formula or weight constants change.
//
// DATA-SUFFICIENCY: Predictions are only emitted when evidence meets the named
// minimum thresholds defined in src/lib/predictive/types.ts. Below the gate,
// state = "insufficientData" is returned — never a fabricated number.

enum PredictiveConfidence {
  LOW
  MEDIUM
  HIGH
}

enum DegradationClass {
  IMPROVING
  STABLE
  DEGRADING
  RAPIDLY_DEGRADING
  INSUFFICIENT_DATA
}

enum FailureProbabilityLevel {
  LOW
  MEDIUM
  HIGH
  INSUFFICIENT_DATA
}

// ── AssetBaseline ─────────────────────────────────────────────────────────────
//
// Baseline statistics per asset, computed over a configurable historical window
// (30 / 90 / 180 days). A baseline cannot be built without meeting the
// data-sufficiency gate (MIN_HEALTH_POINTS_FOR_DEGRADATION + MIN_HISTORY_DAYS).

model AssetBaseline {
  id                  String       @id @default(cuid())
  organizationId      String
  assetId             String
  windowDays          Int          // 30 | 90 | 180
  avgHealthScore      Float?
  stdDevHealthScore   Float?
  avgEfficiency       Float?
  avgAvailability     Float?
  avgRuntime          Float?
  avgDowntime         Float?
  avgAlarmRate        Float?
  sampleCount         Int          // number of health history points used
  coverageDays        Float        // actual calendar days covered by the sample
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  metadata            Json         @default("{}") // formulaVersion, weightSetVersion
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ── AssetRiskScore ────────────────────────────────────────────────────────────
//
// Persisted risk score (0–100) per asset. Updated on demand or on a schedule.
// metadata contains: contributing factors, source evidence IDs, formulaVersion,
// weightSetVersion. confidence derived from telemetry completeness and freshness.

model AssetRiskScore {
  id                  String               @id @default(cuid())
  organizationId      String
  assetId             String
  riskScore           Float                // 0–100
  confidence          PredictiveConfidence
  healthTrendScore    Float                // contribution from health trend (0–30)
  alarmTrendScore     Float                // contribution from alarm trend (0–25)
  kpiDegradationScore Float                // contribution from KPI degradation (0–20)
  telQualityScore     Float                // contribution from telemetry quality (0–15)
  telFreshnessScore   Float                // contribution from telemetry freshness (0–10)
  criticalityFactor   Float                // multiplier from asset type (0.8–1.3)
  createdAt           DateTime             @default(now())
  metadata            Json                 @default("{}") // evidenceIds, formulaVersion, weightSetVersion
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ── FailureIndicator ──────────────────────────────────────────────────────────
//
// Failure probability assessment for an asset at a point in time.
// probability is always an enum level — never a raw float — because
// deterministic classification is more defensible than a pseudo-precise number.

model FailureIndicator {
  id               String                  @id @default(cuid())
  organizationId   String
  assetId          String
  probability      FailureProbabilityLevel
  confidence       PredictiveConfidence
  riskScore        Float                   // snapshot of risk score at calculation time
  degradationClass DegradationClass
  alarmTrend       String                  // "rising" | "stable" | "falling" | "unknown"
  healthTrend      String                  // "improving" | "stable" | "declining" | "unknown"
  evidence         Json                    @default("[]") // PredictiveEvidence[]
  createdAt        DateTime                @default(now())
  metadata         Json                    @default("{}") // formulaVersion, weightSetVersion
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ── RULSnapshot ───────────────────────────────────────────────────────────────
//
// Remaining Useful Life estimate. Stored as a range [minDays, maxDays] to
// reflect projection uncertainty — never a single false-precise number.
// state encodes special conditions (see RULState in types.ts).

model RULSnapshot {
  id               String               @id @default(cuid())
  organizationId   String
  assetId          String
  state            String               // "estimated" | "no_degradation" | "at_threshold" | "insufficientData"
  minDays          Float?               // null if state != "estimated"
  maxDays          Float?               // null if state != "estimated"
  currentScore     Float?               // health score at time of estimation
  degradationRate  Float?               // points/day (negative = degrading)
  degradationClass DegradationClass
  confidence       PredictiveConfidence
  createdAt        DateTime             @default(now())
  metadata         Json                 @default("{}") // formulaVersion, weightSetVersion
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ── MaintenanceRecommendation ─────────────────────────────────────────────────
//
// A maintenance action recommended by the PM engine. Read-only outputs only.
// No write-back to PLCs, no autonomous action, no command dispatch.
// evidence links to real record IDs; confidence reflects data quality.

model MaintenanceRecommendation {
  id                 String               @id @default(cuid())
  organizationId     String
  assetId            String
  recommendationType String               // "inspection" | "alarm_review" | "maintenance_review" | "comms_inspection"
  priority           String               @default("MEDIUM") // "HIGH" | "MEDIUM" | "LOW"
  title              String
  description        String
  confidence         PredictiveConfidence
  evidence           Json                 @default("[]") // PredictiveEvidence[]
  evidenceRecordIds  Json                 @default("[]") // string[] — linked record IDs for traceability
  dismissed          Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  metadata           Json                 @default("{}") // formulaVersion, weightSetVersion
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 40 — Industrial Knowledge Engine
// ════════════════════════════════════════════════════════════════════════════
//
// SAFETY INVARIANT: Knowledge Engine is READ/OBSERVE/EXPLAIN ONLY.
// It MUST NOT control equipment, modify PLC values, trigger maintenance, or
// act autonomously. All outputs are deterministic, traceable, auditable.
//
// BILINGUAL SEARCH: titleNorm / nameNorm columns store pre-normalized FA/EN text.
// See src/lib/knowledge/normalize.ts for the normalization pipeline.
//
// CONFIDENCE SCALE: IndustrialRootCause.confidenceWeight is 0.0–1.0 internally.
// Display: 0.00–0.39 → LOW, 0.40–0.74 → MEDIUM, 0.75–1.00 → HIGH.
//
// VERSIONING:
//   IndustrialKnowledgeArticle.version — monotonic Int, no history table.
//   IndustrialMaintenanceProcedure.version — monotonic Int + mandatory audit diff
//     in AuditLog: { previousVersion, nextVersion, changedFields, changedBy }.
//
// ASSET KNOWLEDGE LINK INTEGRITY: AssetKnowledgeLink has four nullable FKs.
// Exactly ONE must be non-null — enforced by DB CHECK constraint (migration SQL)
// AND service-level validation in src/lib/knowledge/articles.ts.

enum KnowledgeSourceType {
  MANUAL
  ENGINEERING_STANDARD
  MAINTENANCE_HISTORY
  FAILURE_ANALYSIS
  VENDOR_DOCUMENTATION
  INTERNAL_CASE
}

enum FailureSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model KnowledgeCategory {
  id             String                           @id @default(cuid())
  organizationId String
  name           String
  description    String?
  parentId       String?
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  organization   Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         KnowledgeCategory?               @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       KnowledgeCategory[]              @relation("CategoryParent")
  articles       IndustrialKnowledgeArticle[]
  failureModes   IndustrialFailureMode[]
  procedures     IndustrialMaintenanceProcedure[]

  @@unique([organizationId, name])
  @@index([organizationId, createdAt])
}

model IndustrialKnowledgeArticle {
  id             String               @id @default(cuid())
  organizationId String
  categoryId     String?
  title          String
  titleNorm      String
  summary        String
  content        String
  keywords       Json                 @default("[]")
  sourceType     KnowledgeSourceType  @default(MANUAL)
  version        Int                  @default(1)
  status         String               @default("draft")
  authorId       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       KnowledgeCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assetLinks     AssetKnowledgeLink[]

  @@index([organizationId, createdAt])
  @@index([organizationId, title])
}

model IndustrialFailureMode {
  id             String               @id @default(cuid())
  organizationId String
  categoryId     String?
  name           String
  nameNorm       String
  description    String
  severity       FailureSeverity      @default(MEDIUM)
  symptoms       Json                 @default("[]")
  assetTypes     Json                 @default("[]")
  keywords       Json                 @default("[]")
  sourceType     KnowledgeSourceType  @default(MANUAL)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       KnowledgeCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rootCauses     IndustrialRootCause[]
  assetLinks     AssetKnowledgeLink[]

  @@index([organizationId, createdAt])
  @@index([organizationId, name])
}

model IndustrialRootCause {
  id                 String                @id @default(cuid())
  organizationId     String
  failureModeId      String
  description        String
  confidenceWeight   Float                 @default(0.5)
  supportingEvidence Json                  @default("[]")
  sourceType         KnowledgeSourceType   @default(MANUAL)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  failureMode        IndustrialFailureMode @relation(fields: [failureModeId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, failureModeId])
}

model IndustrialMaintenanceProcedure {
  id             String               @id @default(cuid())
  organizationId String
  categoryId     String?
  title          String
  titleNorm      String
  description    String
  steps          Json                 @default("[]")
  assetTypes     Json                 @default("[]")
  estimatedHours Float?
  requiredRoles  Json                 @default("[]")
  safetyNotes    String?
  sourceType     KnowledgeSourceType  @default(MANUAL)
  version        Int                  @default(1)
  status         String               @default("draft")
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       KnowledgeCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assetLinks     AssetKnowledgeLink[]

  @@index([organizationId, createdAt])
  @@index([organizationId, title])
}

model IndustrialEngineeringCase {
  id             String           @id @default(cuid())
  organizationId String
  title          String
  titleNorm      String
  symptoms       Json             @default("[]")
  diagnosis      String?
  resolution     String?
  lessonsLearned String?
  assetTypes     Json             @default("[]")
  assetId        String?
  siteId         String?
  failureModeId  String?
  keywords       Json             @default("[]")
  status         String           @default("open")
  severity       FailureSeverity  @default(MEDIUM)
  reportedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assetLinks     AssetKnowledgeLink[]

  @@index([organizationId, createdAt])
  @@index([organizationId, assetId])
  @@index([organizationId, title])
}

// EXACTLY ONE of (articleId, failureModeId, procedureId, caseId) must be non-null.
// DB CHECK constraint in migration SQL; service-level check in articles.ts.
model AssetKnowledgeLink {
  id             String                          @id @default(cuid())
  organizationId String
  assetId        String
  articleId      String?
  failureModeId  String?
  procedureId    String?
  caseId         String?
  notes          String?
  createdAt      DateTime                        @default(now())
  organization   Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  article        IndustrialKnowledgeArticle?     @relation(fields: [articleId],     references: [id], onDelete: SetNull)
  failureMode    IndustrialFailureMode?           @relation(fields: [failureModeId], references: [id], onDelete: SetNull)
  procedure      IndustrialMaintenanceProcedure? @relation(fields: [procedureId],   references: [id], onDelete: SetNull)
  case           IndustrialEngineeringCase?      @relation(fields: [caseId],        references: [id], onDelete: SetNull)

  @@index([organizationId, assetId])
  @@index([organizationId, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 41 — Industrial Knowledge Graph
// ════════════════════════════════════════════════════════════════════════════
//
// DERIVED VIEW INVARIANT:
// IndustrialKnowledgeGraphNode and IndustrialKnowledgeGraphEdge are
// MATERIALIZED from source tables (Phases 35–40). They are never written
// by application logic outside the graph builder (POST /api/industrial-graph/rebuild).
// Source tables are authoritative; this graph is a cache.
//
// entityId is a SOFT REFERENCE — it points to different source tables
// depending on nodeType. There is no DB foreign key. Referential integrity
// is the builder's responsibility (orphan detection + removal on rebuild).
//
// WEIGHT NORMALIZATION (common 0.0–1.0 scale):
//   confidenceWeight (IndustrialRootCause, 0.0–1.0)       → used directly
//   FailureSeverity enum (LOW/MEDIUM/HIGH/CRITICAL)         → 0.25/0.50/0.75/1.00
//   riskScore (AssetRiskScore, 0–100)                      → divide by 100
//   Structural default (no evidence source)                → 0.50
//
// PATH-FINDING ALGORITHM (findShortestEvidencePath):
//   Dijkstra over edge cost (1.0 − weight) → maximizes cumulative evidence
//   weight → strongest-evidence path, not fewest hops.
//   BIDIRECTIONAL edge types: CONNECTED_TO, RELATED_TO.
//   All other edge types are DIRECTED (source → target only).
//
// STALENESS: KnowledgeGraphSnapshot.createdAt of the latest snapshot per org
// is exposed as lastBuiltAt on every query response. If no snapshot exists or
// lastBuiltAt is older than 24 h, queries include stale:true + stalenessWarning.
// Stale graph always returns results — it never fails.

enum KnowledgeGraphNodeType {
  ASSET            // IndustrialAsset
  FAILURE_MODE     // IndustrialFailureMode
  ROOT_CAUSE       // IndustrialRootCause
  PROCEDURE        // IndustrialMaintenanceProcedure
  ENGINEERING_CASE // IndustrialEngineeringCase
  PREDICTIVE_RISK  // AssetRiskScore (latest per asset)
  TELEMETRY_TAG    // AssetTag
  DIGITAL_TWIN_NODE // DigitalTwinNode
}

enum KnowledgeGraphEdgeType {
  HAS_FAILURE_MODE  // DIRECTED: ASSET → FAILURE_MODE
  CAUSED_BY         // DIRECTED: FAILURE_MODE → ROOT_CAUSE
  MITIGATED_BY      // DIRECTED: FAILURE_MODE → PROCEDURE
  DOCUMENTED_IN     // DIRECTED: FAILURE_MODE|ASSET → ENGINEERING_CASE
  OBSERVED_ON       // DIRECTED: FAILURE_MODE → ASSET (via engineering case)
  CONNECTED_TO      // BIDIRECTIONAL: asset↔tag or twin_node↔twin_node
  DEPENDS_ON        // DIRECTED: DIGITAL_TWIN_NODE → ASSET
  INDICATES_RISK    // DIRECTED: PREDICTIVE_RISK → ASSET
  RELATED_TO        // BIDIRECTIONAL: general relationship
}

// ── IndustrialKnowledgeGraphNode ──────────────────────────────────────────────
//
// One node per (organizationId, nodeType, entityId) triplet.
// entityId is a soft reference — no DB FK — pointing to:
//   ASSET            → IndustrialAsset.id
//   FAILURE_MODE     → IndustrialFailureMode.id
//   ROOT_CAUSE       → IndustrialRootCause.id
//   PROCEDURE        → IndustrialMaintenanceProcedure.id
//   ENGINEERING_CASE → IndustrialEngineeringCase.id
//   PREDICTIVE_RISK  → AssetRiskScore.id (latest per asset at build time)
//   TELEMETRY_TAG    → AssetTag.id
//   DIGITAL_TWIN_NODE → DigitalTwinNode.id

model IndustrialKnowledgeGraphNode {
  id             String                         @id @default(cuid())
  organizationId String
  nodeType       KnowledgeGraphNodeType
  entityId       String                         // soft ref; see comment above
  label          String
  metadata       Json                           @default("{}")
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outboundEdges  IndustrialKnowledgeGraphEdge[] @relation("KGEdgeSource")
  inboundEdges   IndustrialKnowledgeGraphEdge[] @relation("KGEdgeTarget")

  @@unique([organizationId, nodeType, entityId])
  @@index([organizationId, nodeType])
}

// ── IndustrialKnowledgeGraphEdge ──────────────────────────────────────────────
//
// weight: 0.0–1.0 normalized (see WEIGHT NORMALIZATION above).
// evidence: JSON containing source record IDs, formula inputs, and the
//   normalization applied — making every edge fully traceable.

model IndustrialKnowledgeGraphEdge {
  id             String                         @id @default(cuid())
  organizationId String
  sourceNodeId   String
  targetNodeId   String
  edgeType       KnowledgeGraphEdgeType
  weight         Float                          @default(0.5) // 0.0–1.0 normalized
  evidence       Json                           @default("{}") // traceability
  metadata       Json                           @default("{}")
  createdAt      DateTime                       @default(now())
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceNode     IndustrialKnowledgeGraphNode   @relation("KGEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode     IndustrialKnowledgeGraphNode   @relation("KGEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, edgeType])
  @@index([organizationId, edgeType])
  @@index([organizationId, sourceNodeId])
  @@index([organizationId, targetNodeId])
}

enum KnowledgeGraphBuildStatus {
  RUNNING
  SUCCESS
  FAILED
}

// ── KnowledgeGraphSnapshot ────────────────────────────────────────────────────
//
// One row per rebuild attempt. status: RUNNING while in progress, SUCCESS on
// completion, FAILED if the transaction or builder threw. Only SUCCESS rows
// are used as lastBuiltAt. The most recent SUCCESS snapshot's createdAt is
// the graph's lastBuiltAt timestamp. summary holds the build report
// (nodeCount, edgeCount, orphansRemoved, buildDurationMs).

model KnowledgeGraphSnapshot {
  id             String                   @id @default(cuid())
  organizationId String
  name           String
  status         KnowledgeGraphBuildStatus @default(SUCCESS)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  summary        Json                     @default("{}")
  createdAt      DateTime                 @default(now())
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 42 — Multi-Site Industrial Intelligence
// ════════════════════════════════════════════════════════════════════════════
//
// ACCESS MODEL: Organization-level only. All sites within an org are
// included. Site-level RBAC is a Phase 43/44 hardening requirement.
//
// SNAPSHOT LIFECYCLE: POST /api/multi-site/benchmarks → RUNNING → SUCCESS/FAILED.
// GETs read the latest SUCCESS benchmark. Staleness threshold: 4 hours.
//
// KPI NORMALIZATION:
//   availability + efficiency + healthScore: 0–100 rates — comparable directly.
//   Site value = mean(metric) across qualifying assets.
//   runtime + downtime counts: excluded from cross-site ranking (not rate-normalized).
//
// DATA-SUFFICIENCY GATE:
//   A site with 0 qualifying assets → dataStatus="insufficientData" → excluded from ranking.
//   A site with lastDataTimestamp > RISK_DATA_MAX_STALE_HOURS → dataStatus="stale",
//   confidence="LOW" → included in ranking but labeled low-confidence.
//
// FAILURE PATTERN CRITERION (deterministic):
//   Same IndustrialFailureMode.id appearing in IndustrialEngineeringCase rows
//   with 2+ distinct non-null siteId values. No fuzzy matching. No ML.

enum MultiSiteSnapshotStatus {
  RUNNING
  SUCCESS
  FAILED
}

// ── MultiSiteBenchmark ────────────────────────────────────────────────────────
//
// One row per benchmark run. Contains org-level summary and links to per-site
// snapshots. Child rows (SiteRiskSnapshot, SiteKPIComparison,
// CrossSiteFailurePattern) are created atomically in the same transaction.

model MultiSiteBenchmark {
  id              String                  @id @default(cuid())
  organizationId  String
  status          MultiSiteSnapshotStatus @default(SUCCESS)
  periodLabel     String
  siteCount       Int
  summary         Json                    @default("{}")
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  computedAt      DateTime                @default(now())
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  riskSnapshots   SiteRiskSnapshot[]
  kpiSnapshots    SiteKPIComparison[]
  failurePatterns CrossSiteFailurePattern[]

  @@index([organizationId, computedAt])
  @@index([organizationId, status])
}

// ── SiteRiskSnapshot ──────────────────────────────────────────────────────────
//
// Per-site risk aggregate for one benchmark run. avgRiskScore is the MEAN
// of latest AssetRiskScore.riskScore across qualifying assets (not worst-case).
// maxRiskScore captures the worst single asset for operational awareness.
// null values mean dataStatus="insufficientData".

model SiteRiskSnapshot {
  id                String             @id @default(cuid())
  organizationId    String
  benchmarkId       String
  siteId            String
  siteName          String
  assetCount        Int
  assetsWithData    Int
  avgRiskScore      Float?
  maxRiskScore      Float?
  minRiskScore      Float?
  riskDistribution  Json               @default("{}")
  dataStatus        String
  confidence        String
  lastDataTimestamp DateTime?
  computedAt        DateTime           @default(now())
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  benchmark         MultiSiteBenchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([organizationId, computedAt])
  @@index([benchmarkId])
}

// ── SiteKPIComparison ─────────────────────────────────────────────────────────
//
// Per-site KPI aggregate for one benchmark run.
// avgAvailability / avgEfficiency / avgHealthScore: mean across qualifying
// assets, all 0–100 rates, directly comparable across sites.
// runtime/downtime counts are NOT stored here — not cross-site comparable.

model SiteKPIComparison {
  id                 String             @id @default(cuid())
  organizationId     String
  benchmarkId        String
  siteId             String
  siteName           String
  periodLabel        String
  avgAvailability    Float?
  avgEfficiency      Float?
  avgHealthScore     Float?
  assetCount         Int
  assetsWithKpiData  Int
  dataStatus         String
  lastDataTimestamp  DateTime?
  computedAt         DateTime           @default(now())
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  benchmark          MultiSiteBenchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([organizationId, computedAt])
  @@index([benchmarkId])
}

// ── CrossSiteFailurePattern ───────────────────────────────────────────────────
//
// A failure mode that appears in IndustrialEngineeringCase rows across 2+
// distinct non-null siteId values within the org. Deterministic: same DB
// state → same patterns. Evidence stores caseIds + assetIds by site.

model CrossSiteFailurePattern {
  id                 String             @id @default(cuid())
  organizationId     String
  benchmarkId        String
  failureModeId      String
  failureModeName    String
  severity           String
  siteIds            Json
  siteCount          Int
  caseCount          Int
  affectedAssetTypes Json
  evidence           Json               @default("{}")
  computedAt         DateTime           @default(now())
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  benchmark          MultiSiteBenchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([organizationId, computedAt])
  @@index([benchmarkId])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 43 — Industrial Multi-Tenant Security & Site Isolation
// ════════════════════════════════════════════════════════════════════════════
//
// OWNER / ADMIN access model:
//   OrgRole OWNER and ADMIN have IMPLICIT access to all active sites in their
//   org. This is resolved DYNAMICALLY at runtime by querying IndustrialSite.
//   NO UserSite rows are created for OWNER or ADMIN — ever. Not at membership
//   creation, not in the backfill, not when new sites are added.
//   UserSite rows exist ONLY for explicit site assignments (MANAGER, ENGINEER,
//   VIEWER, BILLING_ADMIN → respective SiteRole).
//
// BACKFILL RULE:
//   On migration: cross-join non-OWNER/ADMIN ACTIVE members × sites in same org.
//   Role mapping: MANAGER→SITE_MANAGER, ENGINEER→SITE_ENGINEER,
//   all others (VIEWER, BILLING_ADMIN, MEMBER)→SITE_VIEWER.
//   ON CONFLICT DO NOTHING (idempotent).
//
// ISOLATION SCOPE:
//   Site-gated: IndustrialSite, IndustrialGateway, IndustrialAsset,
//     TelemetryRecord, DigitalTwinNode, DigitalTwinLayout, KPIRecord,
//     AssetHealthHistory, AssetRiskScore, MultiSiteBenchmark (children).
//   Org-gated only (no site gate): IndustrialFailureMode, IndustrialRootCause,
//     IndustrialMaintenanceProcedure, IndustrialKnowledgeArticle,
//     IndustrialEngineeringCase, KnowledgeGraphNode/Edge.
//
// KG TRAVERSAL ISOLATION:
//   ASSET nodes filtered to allowedAssetIds at query time. Non-ASSET nodes
//   remain visible (org-level knowledge). Dangling edges are dropped.

enum SiteRole {
  SITE_ADMIN
  SITE_MANAGER
  SITE_ENGINEER
  SITE_OPERATOR
  SITE_VIEWER
}

enum SiteMemberStatus {
  ACTIVE
  SUSPENDED
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 48 — Notification System
// ════════════════════════════════════════════════════════════════════════════
//
// Centralized in-app notification store. Notifications are always created even
// if email delivery fails — the notification system is PRIMARY, email is
// SECONDARY. All insertions are best-effort (never block business logic).
//
// type: info | success | warning | error | security
// isRead: false on creation; flipped by explicit user action
//
// Index strategy:
//   (userId, createdAt) — primary feed query (ORDER BY createdAt DESC)
//   (userId, isRead)    — unread-count queries (WHERE isRead = false)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 49 — Asset Intelligence Automation
// ════════════════════════════════════════════════════════════════════════════
//
// SAFETY INVARIANT: Automation is READ/ANALYZE/ALERT ONLY.
// The engine recalculates risk, health, and maintenance recommendations from
// existing telemetry and history. It NEVER writes to PLCs or control systems.
//
// ALERT DEDUPLICATION: Only one non-dismissed alert per (assetId, alertType)
// is ever active. The automation engine skips creating an alert when an
// undismissed alert of the same type already exists for the same asset.
//
// SNAPSHOT PURPOSE: AssetIntelligenceSnapshot stores one row per automation
// run per asset. deltaRiskScore / deltaHealth track change from the previous
// snapshot so trends and degradation velocity can be computed without a full
// history scan.

enum AssetAlertType {
  CRITICAL_RISK
  HEALTH_DEGRADATION
  COMMUNICATION_FAILURE
  KNOWLEDGE_COVERAGE_LOW
}

enum AssetAlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model AssetAlert {
  id             String             @id @default(cuid())
  organizationId String
  assetId        String
  alertType      AssetAlertType
  severity       AssetAlertSeverity
  title          String
  description    String
  metadata       Json               @default("{}")
  dismissed      Boolean            @default(false)
  dismissedAt    DateTime?
  dismissedBy    String?
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
  @@index([organizationId, alertType, createdAt])
  @@index([organizationId, dismissed, createdAt])
}

model AssetIntelligenceSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  assetId        String
  riskScore      Float?
  riskLevel      String       @default("UNKNOWN")
  healthScore    Float?
  healthStatus   String       @default("unknown")
  healthTrend    String       @default("unknown")
  tagCount       Int          @default(0)
  knowledgeTotal Int          @default(0)
  deltaRiskScore Float?
  deltaHealth    Float?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assetId, createdAt])
}

// Explicit site membership. OWNER/ADMIN never have rows here (implicit access).
model UserSite {
  id             String           @id @default(cuid())
  userId         String
  siteId         String
  organizationId String
  role           SiteRole         @default(SITE_VIEWER)
  status         SiteMemberStatus @default(ACTIVE)
  // OrganizationMember.id of the person who granted this access (loose ref — no FK)
  grantedById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  site           IndustrialSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A user may only have one membership per site
  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
  @@index([organizationId, userId])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 58B — ATS Persistence Layer
// ════════════════════════════════════════════════════════════════════════════
//
// MULTI-TENANT: All tables except AtsCandidate are organization-scoped.
// AtsCandidate is global (one profile per email, reused across orgs).
//
// SOFT DELETE: deletedAt on AtsJob, AtsCandidate, AtsApplication.
// All queries must filter WHERE deletedAt IS NULL.
//
// PIPELINE AUDIT: Every status change on AtsApplication creates an
// AtsPipelineEvent row. Applications never lose history.
//
// SCORING: AtsCandidateScore is 1:1 with AtsApplication (unique constraint).
// Rescoring overwrites via upsert on applicationId.

enum AtsJobStatus {
  DRAFT
  OPEN
  CLOSED
  ON_HOLD
}

enum AtsApplicationStatus {
  APPLIED
  SCREENING
  TECHNICAL_REVIEW
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum AtsInterviewType {
  PHONE_SCREEN
  VIDEO_CALL
  TECHNICAL
  PANEL
  ONSITE
}

enum AtsInterviewDecision {
  PENDING
  ADVANCE
  HOLD
  REJECT
}

// ── AtsJob ─────────────────────────────────────────────────────────────────────
//
// Organization-scoped job posting. isPublic=true → visible on careers portal.
// postedById is a loose reference to User.id (no FK — recruiter may leave org).

model AtsJob {
  id               String         @id @default(cuid())
  organizationId   String
  departmentId     String?        // loose ref to Department
  title            String
  description      String
  requirements     Json           @default("[]")
  responsibilities Json           @default("[]")
  benefits         Json           @default("[]")
  skills           Json           @default("[]")
  location         String
  locationType     String         @default("onsite")  // onsite | remote | hybrid
  department       String
  salaryCurrency   String         @default("USD")
  salaryMin        Int?
  salaryMax        Int?
  status           AtsJobStatus   @default(DRAFT)
  closingDate      DateTime?
  postedById       String?
  isPublic         Boolean        @default(true)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications     AtsApplication[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([status, isPublic])
}

// ── AtsCandidate ──────────────────────────────────────────────────────────────
//
// Global candidate identity. One profile per email address.
// userId links to User when the candidate creates an account.
// userId is nullable — candidates can apply without registering.
// Once a candidate registers, their User.id is set here permanently.

model AtsCandidate {
  id                String         @id @default(cuid())
  userId            String?        @unique
  email             String         @unique
  name              String
  phone             String?
  location          String?
  linkedinUrl       String?
  portfolioUrl      String?
  summary           String?
  skills            Json           @default("[]")
  languages         Json           @default("[]")
  workAuthorization String         @default("citizen")
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  applications      AtsApplication[]
  // Phase 60: Academy — candidates can be enrolled in training
  academyEnrollments AcademyEnrollment[]

  @@index([userId])
}

// ── AtsApplication ────────────────────────────────────────────────────────────
//
// One application per (job, candidate). Enforced by @@unique([jobId, candidateId]).
// experience / education / certifications: JSON arrays of structured records.
// assignedTo is a loose ref to the recruiter User.id managing this application.

model AtsApplication {
  id             String               @id @default(cuid())
  organizationId String
  jobId          String
  candidateId    String
  status         AtsApplicationStatus @default(APPLIED)
  coverLetter    String?
  resumeUrl      String?
  resumeText     String?
  experience     Json                 @default("[]")
  education      Json                 @default("[]")
  certifications Json                 @default("[]")
  totalYearsExp  Int?
  source         String               @default("careers_portal")
  notes          String?
  assignedTo     String?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job            AtsJob               @relation(fields: [jobId], references: [id])
  candidate      AtsCandidate         @relation(fields: [candidateId], references: [id])
  interviews     AtsInterview[]
  pipelineEvents AtsPipelineEvent[]
  score          AtsCandidateScore?

  @@unique([jobId, candidateId])
  @@index([organizationId, status])
  @@index([organizationId, jobId])
  @@index([candidateId])
}

// ── AtsInterview ──────────────────────────────────────────────────────────────
//
// Scheduled interview for an application. interviewerId is a loose ref to User.id
// (no FK — interviewer may leave org). interviewerName is denormalized for display.
// All score fields are optional until the interview is completed (completedAt set).

model AtsInterview {
  id                 String               @id @default(cuid())
  organizationId     String
  applicationId      String
  interviewType      AtsInterviewType     @default(VIDEO_CALL)
  scheduledAt        DateTime
  durationMinutes    Int                  @default(60)
  interviewerId      String?
  interviewerName    String?
  location           String?
  notes              String?
  feedback           String?
  technicalScore     Int?
  culturalScore      Int?
  communicationScore Int?
  overallScore       Int?
  decision           AtsInterviewDecision @default(PENDING)
  completedAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  application        AtsApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([organizationId, applicationId])
  @@index([organizationId, scheduledAt])
}

// ── AtsPipelineEvent ──────────────────────────────────────────────────────────
//
// Immutable audit log of every status transition on an AtsApplication.
// fromStatus is nullable on the first event (APPLIED, no prior status).
// changedByName is denormalized for history display when user leaves.

model AtsPipelineEvent {
  id             String                @id @default(cuid())
  organizationId String
  applicationId  String
  fromStatus     AtsApplicationStatus?
  toStatus       AtsApplicationStatus
  changedById    String?
  changedByName  String?
  notes          String?
  createdAt      DateTime              @default(now())
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  application    AtsApplication        @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([organizationId, applicationId, createdAt])
  @@index([organizationId, createdAt])
}

// ── AtsCandidateScore ─────────────────────────────────────────────────────────
//
// Scoring result from the ATS rule-based engine (see src/lib/ats/scoring.ts).
// 1:1 with AtsApplication. Upsert on applicationId for re-scoring.
// scoringVersion tracks which formula version produced the result.

model AtsCandidateScore {
  id                 String         @id @default(cuid())
  organizationId     String
  applicationId      String         @unique
  skillScore         Int            @default(0)
  experienceScore    Int            @default(0)
  locationScore      Int            @default(0)
  authorizationScore Int            @default(0)
  salaryScore        Int            @default(0)
  industryScore      Int            @default(0)
  overallScore       Int            @default(0)
  riskFlags          Json           @default("[]")
  explanations       Json           @default("[]")
  scoredAt           DateTime       @default(now())
  scoringVersion     String         @default("1.0")
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  application        AtsApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([organizationId, overallScore])
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 60 — Hermes Training Academy
// ════════════════════════════════════════════════════════════════════════════
//
// STRUCTURE: Course → Module → Lesson → Quiz → Certificate
//
// MULTI-TENANT: All tables are organization-scoped.
//
// ENROLLMENT: AcademyEnrollment is the hub — links User (always) and
// optionally AtsCandidate. @@unique([courseId, userId]) prevents duplicates.
//
// PROGRESS: AcademyProgress is lesson-level. Completion is computed by
// comparing progress count against lesson count for the course.
//
// QUIZ SECURITY: Correct answers stored in AcademyQuizQuestion.correctAnswers
// (JSONB). Never returned by GET /api/academy/quizzes/[id]. Scoring done
// server-side in POST /api/academy/quizzes/[id]/attempt.
//
// CERTIFICATION: AcademyCertificate issued when:
//   1. All published lessons in the course are complete.
//   2. All quizzes in the course are passed.
//   3. Course has certificateEnabled = true.
//   certificateNumber is globally unique (includes org slug + sequential ID).
//   verificationToken enables public /academy/certificate/[id] page.

// ── AcademyCourse ─────────────────────────────────────────────────────────────

model AcademyCourse {
  id                String              @id @default(cuid())
  organizationId    String
  title             String
  slug              String
  description       String
  category          String              @default("general")
  level             String              @default("beginner")
  estimatedHours    Int                 @default(0)
  thumbnailUrl      String?
  isPublished       Boolean             @default(false)
  isFeatured        Boolean             @default(false)
  enrollmentType    String              @default("open")
  certificateEnabled Boolean            @default(true)
  passingScore      Int                 @default(80)
  instructorName    String?
  instructorBio     String?
  tags              Json                @default("[]")
  targetAudience    Json                @default("[]")
  createdById       String?
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modules           AcademyModule[]
  lessons           AcademyLesson[]
  quizzes           AcademyQuiz[]
  enrollments       AcademyEnrollment[]
  certificates      AcademyCertificate[]

  @@unique([organizationId, slug])
  @@index([organizationId, isPublished])
  @@index([organizationId, category])
}

// ── AcademyModule ─────────────────────────────────────────────────────────────

model AcademyModule {
  id             String          @id @default(cuid())
  courseId       String
  organizationId String
  title          String
  description    String?
  orderIndex     Int             @default(0)
  isPublished    Boolean         @default(true)
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  course         AcademyCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons        AcademyLesson[]

  @@index([courseId, orderIndex])
}

// ── AcademyLesson ─────────────────────────────────────────────────────────────

model AcademyLesson {
  id              String           @id @default(cuid())
  moduleId        String
  courseId        String
  organizationId  String
  title           String
  content         String?
  lessonType      String           @default("text")
  videoUrl        String?
  resourceUrl     String?
  resourceName    String?
  durationMinutes Int              @default(0)
  orderIndex      Int              @default(0)
  isPublished     Boolean          @default(true)
  isFree          Boolean          @default(false)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  module          AcademyModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  course          AcademyCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizzes         AcademyQuiz[]
  progress        AcademyProgress[]

  @@index([courseId, orderIndex])
  @@index([moduleId, orderIndex])
}

// ── AcademyQuiz ───────────────────────────────────────────────────────────────

model AcademyQuiz {
  id               String               @id @default(cuid())
  courseId         String
  lessonId         String?
  organizationId   String
  title            String
  description      String?
  passingScore     Int                  @default(80)
  timeLimitMinutes Int?
  maxAttempts      Int?
  shuffleQuestions Boolean              @default(false)
  isPublished      Boolean              @default(true)
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  course           AcademyCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson           AcademyLesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions        AcademyQuizQuestion[]
  attempts         AcademyQuizAttempt[]

  @@index([courseId])
  @@index([lessonId])
}

// ── AcademyQuizQuestion ───────────────────────────────────────────────────────

model AcademyQuizQuestion {
  id             String        @id @default(cuid())
  quizId         String
  organizationId String
  questionText   String
  questionType   String        @default("single_choice")
  options        Json          @default("[]")
  correctAnswers Json          @default("[]")
  explanation    String?
  points         Int           @default(1)
  orderIndex     Int           @default(0)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  quiz           AcademyQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, orderIndex])
}

// ── AcademyEnrollment ─────────────────────────────────────────────────────────

model AcademyEnrollment {
  id              String               @id @default(cuid())
  courseId        String
  organizationId  String
  userId          String
  candidateId     String?
  enrolledById    String?
  completedAt     DateTime?
  progressPercent Int                  @default(0)
  status          String               @default("active")
  expiresAt       DateTime?
  source          String               @default("self")
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  course          AcademyCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate       AtsCandidate?        @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  progress        AcademyProgress[]
  certificate     AcademyCertificate?
  quizAttempts    AcademyQuizAttempt[]

  @@unique([courseId, userId])
  @@index([organizationId, userId])
  @@index([organizationId, courseId])
  @@index([candidateId])
}

// ── AcademyProgress ───────────────────────────────────────────────────────────

model AcademyProgress {
  id               String            @id @default(cuid())
  enrollmentId     String
  lessonId         String
  organizationId   String
  userId           String
  completedAt      DateTime?
  timeSpentSeconds Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  enrollment       AcademyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson           AcademyLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([userId])
}

// ── AcademyCertificate ────────────────────────────────────────────────────────

model AcademyCertificate {
  id                String            @id @default(cuid())
  organizationId    String
  courseId          String
  userId            String
  enrollmentId      String            @unique
  certificateNumber String            @unique
  verificationToken String            @unique
  issuedAt          DateTime          @default(now())
  expiresAt         DateTime?
  metadata          Json              @default("{}")
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course            AcademyCourse     @relation(fields: [courseId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  enrollment        AcademyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([organizationId, courseId])
  @@index([verificationToken])
}

// ── AcademyQuizAttempt ────────────────────────────────────────────────────────

model AcademyQuizAttempt {
  id               String            @id @default(cuid())
  quizId           String
  enrollmentId     String
  userId           String
  organizationId   String
  answers          Json              @default("[]")
  score            Int               @default(0)
  passed           Boolean           @default(false)
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  timeSpentSeconds Int               @default(0)
  attemptNumber    Int               @default(1)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  quiz             AcademyQuiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enrollment       AcademyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId, enrollmentId])
  @@index([enrollmentId])
  @@index([userId])
}
