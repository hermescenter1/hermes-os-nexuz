// Hermes OS — Phase 11A database foundation.
//
// This schema describes the Phase 2 Postgres persistence layer. In V1 it is
// OPTIONAL: when DATABASE_URL is absent the app runs entirely in session mode
// and never touches Prisma. Models mirror the existing JSON/session shapes so
// migration is a straight copy when the database is provisioned.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model EngineeringCase {
  id                String   @id @default(cuid())
  title             String
  vendor            String
  domain            String
  problem           String
  rootCause         String
  secondaryCauses   Json
  verificationSteps Json
  correctiveActions Json
  safetyNotes       String
  tags              Json
  confidence        Int
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KnowledgeArticle {
  id                String   @id @default(cuid())
  title             String
  domain            String
  vendor            String?
  summary           String
  content           String
  failureModes      Json
  diagnosticGuidance Json
  verificationSteps Json
  correctiveActions Json
  safetyNotes       String
  tags              Json
  confidence        Int
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AnalysisRecord {
  id         String   @id @default(cuid())
  query      String
  locale     String
  mode       String
  domains    Json
  vendors    Json
  cases      Json
  knowledge  Json
  confidence Float
  riskLevel  String
  isUnknown  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model UnknownAnalysis {
  id               String   @id @default(cuid())
  query            String
  locale           String
  confidence       Float
  suggestedDomains Json
  suggestedVendors Json
  status           String   @default("open")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---- Phase 16A: document ingestion foundation (additive; no upload route,
// no extraction, no embedding wiring yet) ----
//
// `Document` is the source-file metadata row — title, status, and a
// `storageKey` POINTER into object storage (MinIO/S3-compatible; see
// src/lib/documents/object-storage.ts). The raw file bytes are never
// stored here. `DocumentChunk` below (Phase 14C) is the per-chunk
// embedding store a future ingestion worker (Phase 16B) will populate from
// a Document's extracted text.
//
// Deliberately NO foreign key from `DocumentChunk.documentId` to
// `Document.id`: Phase 15's Brain<->RAG integration already writes
// DocumentChunk rows (when HERMES_RAG_MODE=pgvector) whose `documentId` is
// an EngineeringCase or knowledge-library id, not a real Document row — a
// hard FK would break that existing, working path. The two tables stay
// loosely coupled by convention, exactly as `DocumentChunk`'s own Phase
// 14C header comment already documents.
model Document {
  id                String    @id @default(cuid())
  title             String
  sourceType        String
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  storageProvider   String    @default("local")
  storageKey        String
  extractedTextKey  String?
  contentHash       String?
  metadata          Json      @default("{}")
  status            String    @default("uploaded")
  error             String?
  chunkCount        Int       @default(0)
  // Phase 16C: set whenever POST /api/documents/[id]/process completes
  // (success or failure) — distinct from `updatedAt`, which already
  // changes on the upload flow's own internal storageKey-set step.
  lastProcessedAt   DateTime?
  uploadedBy        String?
  tenantId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([sourceType])
}

// ---- Phase 16C: pre-embedding chunk storage (additive) ----
//
// `DocumentTextChunk` holds chunk TEXT only — no embedding, no vector
// column. Deliberately a SEPARATE model from `DocumentChunk` above
// (Phase 14C): that table's `embedding` column is NOT NULL pgvector, so it
// cannot represent a chunk that has no embedding yet. Phase 16D's
// embedding step is expected to read these rows and write the
// corresponding `DocumentChunk` row once a real embedding provider is
// wired in — the two tables are pipeline stages, not duplicates.
//
// No foreign key to `Document` — consistent with `DocumentChunk`'s own
// loose-coupling-by-convention (see that model's comment); application
// code (the DELETE /api/documents/[id] route) is responsible for cleaning
// up a document's chunks when the document itself is deleted.
//
// ---- Phase 16D / 17C: embedding columns (Phase 16D additive; Phase 17C resize) ----
//
// `embedding` uses the same `Unsupported(...)` escape hatch as
// `DocumentChunk.embedding` above. Phase 16D used vector(64) for the mock
// provider; Phase 17C resizes to vector(1536) to match text-embedding-3-small
// (the same dimension as DocumentChunk — both tables now share the same vector
// space). See src/lib/documents/config.ts's `DOCUMENT_CHUNK_EMBEDDING_DIMENSIONS`
// for the single source of truth this literal must match, and
// src/lib/documents/chunk-vector-store.ts for the raw-SQL-only access
// this column requires (invisible to the typed Prisma client, exactly
// like `DocumentChunk.embedding`).
model DocumentTextChunk {
  id                  String                     @id @default(cuid())
  documentId          String
  position            Int
  text                String
  charCount           Int
  tokenCount          Int?
  contentHash         String?
  metadata            Json                       @default("{}")
  status              String                     @default("chunked")
  embedding           Unsupported("vector(1536)")?
  embeddingModel      String?
  embeddingDimensions Int?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([documentId, position])
  @@index([documentId])
}

// ---- Phase 14C: RAG persistence (additive; NOT wired into /api/brain) ----
//
// `embedding` uses Prisma's `Unsupported(...)` escape hatch: pgvector's
// `vector` type has no native Prisma equivalent, so this column is invisible
// to the generated Prisma Client — every read/write against it goes through
// raw SQL in `src/lib/rag/vector-store-pgvector.ts`, exactly like every
// other column below is reachable through the typed client as usual.
//
// The `vector` extension itself is enabled by the migration's own SQL
// (`CREATE EXTENSION IF NOT EXISTS vector;` — see
// prisma/migrations/20260616000000_add_document_chunk_pgvector/migration.sql),
// not by Prisma's `extensions =` datasource block — deliberately avoided so
// this phase doesn't also have to adopt the `postgresqlExtensions` preview
// feature for one column.
//
// Dimension is fixed at 1536 (OpenAI's text-embedding-3-small — see
// src/lib/rag/config.ts's PGVECTOR_DIMENSIONS, the single source of truth
// this literal must match). A pgvector column's width cannot be altered in
// place without rewriting every row; switching the canonical embedding
// model/dimension requires a NEW migration, not an edit to this one.
//
// `model`/`dimensions` are stored per-row (not just relied on globally) so
// a future re-embedding migration can identify which rows came from which
// provider/model before rewriting them.
model DocumentChunk {
  id         String                @id
  documentId String
  sourceType String
  text       String
  position   Int
  metadata   Json                  @default("{}")
  model      String
  dimensions Int
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([documentId])
  @@index([sourceType])
  // The HNSW similarity index (`CREATE INDEX ... USING hnsw (embedding
  // vector_cosine_ops)`) lives only in the migration SQL — Prisma's schema
  // language has no `@@index` syntax for an operator-class-based index
  // type, so it cannot be expressed here.
}

// ---- Phase 19A: Project Intelligence Foundation (additive) ----
//
// `Project` is an organisational context that memories (and future artefacts)
// can be tagged with. Not required — all existing fields remain optional.
// Memories in the same project receive a ranking boost during retrieval
// (Phase 19A WEIGHTS.PROJECT = 20 pts) when HERMES_PROJECT_INTELLIGENCE_ENABLED.
model Project {
  id          String              @id @default(cuid())
  name        String
  description String
  status      String              @default("active")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memories    EngineeringMemory[]

  @@index([status])
}

// ---- Phase 18A: Engineering Memory Foundation (additive) ----
//
// `EngineeringMemory` is an explicitly-saved engineering analysis record.
// Not auto-populated on every Brain request (Phase 18C will add that).
// Operators/engineers POST notable analyses to /api/memory; field feedback
// is collected via /api/memory/[id]/feedback in `MemoryFeedback`.
//
// `outcome` on `EngineeringMemory` mirrors the latest feedback outcome for
// quick filtering. `MemoryFeedback` is the append-only audit trail.
//
// `projectId` (Phase 19A, nullable): optional link to a Project record.
// SET NULL on project delete keeps the memory row intact.
model EngineeringMemory {
  id                 String           @id @default(cuid())
  query              String
  domain             String
  analysisSummary    String
  confidence         Float
  relatedCaseIds     Json             @default("[]")
  relatedDocumentIds Json             @default("[]")
  outcome            String           @default("unknown")
  notes              String?
  projectId          String?
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  feedback           MemoryFeedback[]

  @@index([domain])
  @@index([outcome])
  @@index([projectId])
}

model MemoryFeedback {
  id          String            @id @default(cuid())
  memoryId    String
  outcome     String
  notes       String?
  submittedBy String?
  createdAt   DateTime          @default(now())
  memory      EngineeringMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
}

// ---- Phase 12A / Phase 28: authentication + RBAC ----

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  role                 String               @default("customer") // superadmin | admin | engineer | customer | viewer
  // Phase 28: email verification
  emailVerified        Boolean              @default(false)
  emailVerifiedAt      DateTime?
  // Phase 28: brute-force protection
  failedLoginAttempts  Int                  @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  sessions             AuthSession[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  verificationTokens   VerificationToken[]
  passwordResetTokens  PasswordResetToken[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 28: JWT refresh token (stored as SHA-256 hash, never plaintext)
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Phase 28: email verification tokens (plaintext — one-time use)
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Phase 28: password-reset tokens (stored as SHA-256 hash)
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([userId])
}
