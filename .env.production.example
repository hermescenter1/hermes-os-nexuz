# ─── Hermes OS — Production Environment Template (Phase 45) ──────────────────
# Copy to .env.production on your VPS and fill in all values before starting.
# NEVER commit this file with real secrets filled in.
#
# Generate strong secrets with:
#   openssl rand -hex 64    (for JWT / auth secrets — min 64 chars recommended)
#   openssl rand -base64 32 (for shorter secrets)

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Required in production (unless HERMES_STORAGE_MODE=session).
# In Docker Compose the host is the service name (internal network).
DATABASE_URL=postgresql://hermes:STRONG_DB_PASSWORD@postgres:5432/hermes_db
HERMES_STORAGE_MODE=database

# ── Postgres container init ───────────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=STRONG_DB_PASSWORD
POSTGRES_DB=hermes_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for multi-instance auth and API rate limiting.
REDIS_URL=redis://:STRONG_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=STRONG_REDIS_PASSWORD

# ── JWT / Auth secrets ────────────────────────────────────────────────────────
# Resolution order: JWT_SECRET → JWT_ACCESS_SECRET → AUTH_SECRET → NEXTAUTH_SECRET
# Set at least JWT_SECRET. Use openssl rand -hex 64 to generate.
JWT_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64
JWT_ACCESS_SECRET=REPLACE_WITH_DIFFERENT_64_HEX_CHARS
AUTH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET

# ── Seed administrator ────────────────────────────────────────────────────────
# Created on first boot. Change ADMIN_PASSWORD immediately after first login.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_INITIAL_PASSWORD
ADMIN_NAME=Administrator

# ── Email delivery ────────────────────────────────────────────────────────────
# EMAIL_PROVIDER: "console" (default) | "smtp"
#
#   console — prints emails to stdout only; NO delivery occurs.
#             The UI will truthfully inform users that email is not configured.
#             Safe for initial deployment / development.
#
#   smtp    — delivers via SMTP.  All four SMTP_* vars are REQUIRED.
#             The UI tells the user to check their inbox only when delivery
#             actually succeeds.  On failure the UI shows a contact-admin message.
#
# Recommended free / low-cost SMTP providers for production:
#   Resend (resend.com): SMTP_HOST=smtp.resend.com SMTP_PORT=465
#   Mailgun:             SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
#   Gmail App Password:  SMTP_HOST=smtp.gmail.com   SMTP_PORT=587
#
# To test SMTP before go-live:
#   npx nodemailer-test (requires nodemailer dev dep)
#   OR point SMTP_HOST at Mailtrap / Mailpit for inbox inspection.
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@yourdomain.com
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/backups/postgres
BACKUP_RETENTION_DAYS=30
POSTGRES_CONTAINER=hermes-postgres-1

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARN | ERROR | FATAL (default: INFO in production)
LOG_LEVEL=INFO

# ── Graceful shutdown ─────────────────────────────────────────────────────────
# Milliseconds to drain in-flight requests before closing DB/Redis connections.
# Keep below Docker --stop-timeout (default 10 000 ms).
SHUTDOWN_DRAIN_MS=5000

# ── AI / OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-real-production-key
DOCUMENT_EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Feature flags ─────────────────────────────────────────────────────────────
HERMES_RAG_MODE=pgvector
HERMES_PROJECT_INTELLIGENCE_ENABLED=true
