# ─── Hermes OS — Production Environment Template ────────────────────────────
# Copy to .env.production on your VPS and fill in real values.
# NEVER commit this file with real secrets filled in.
#
# Generate strong secrets with:
#   openssl rand -hex 64    (for JWT secrets)
#   openssl rand -base64 32 (for other secrets)

# ─── Database ────────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name "postgres" (internal network)
DATABASE_URL="postgresql://hermes:STRONG_DB_PASSWORD@postgres:5432/hermes_db"
HERMES_STORAGE_MODE=database

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_OUTPUT_OF__openssl_rand_hex_64"

# ─── App URL ─────────────────────────────────────────────────────────────────
APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER="smtp"
EMAIL_FROM="noreply@yourdomain.com"
SMTP_HOST="smtp.yourdomain.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"

# ─── Redis ────────────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name "redis"
REDIS_URL="redis://:REDIS_PASSWORD@redis:6379"
REDIS_PASSWORD="STRONG_REDIS_PASSWORD"

# ─── Postgres container init ─────────────────────────────────────────────────
POSTGRES_USER="hermes"
POSTGRES_PASSWORD="STRONG_DB_PASSWORD"
POSTGRES_DB="hermes_db"

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-real-production-key"
ANTHROPIC_API_KEY="your-anthropic-key-if-used"
DOCUMENT_EMBEDDINGS_PROVIDER="openai"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ─── Feature flags ────────────────────────────────────────────────────────────
HERMES_RAG_MODE="pgvector"
HERMES_PROJECT_INTELLIGENCE_ENABLED="true"
